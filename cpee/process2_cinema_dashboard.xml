        <code>
          <signal/>
          <prepare>endpoints.frames_init += attributes.framesid</prepare>
          <finalize output="result"/>
          <update output="result"/>
          <rescue output="result"/>
        </code>
        <annotations>
          <_generic/>
          <_timing>
            <_timing_weight/>
            <_timing_avg/>
            <explanations/>
