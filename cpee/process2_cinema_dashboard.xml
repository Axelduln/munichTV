            <_probability_min/>
            <_probability_max/>
            <_probability_avg/>
          </_probability>
        </alternative>
        <otherwise/>
      </choose>
      <loop eid="e2" mode="pre_test" condition="data.running">
        <parallel eid="e3" wait="1" cancel="last">
          <parallel_branch>
            <call id="d2" endpoint="frames_display">
              <parameters>
                <label>Show Landing Page</label>
                <color/>
                <arguments>
                  <type>wait</type>
                  <lx>0</lx>
                  <ly>0</ly>
                  <x_amount>100</x_amount>
                  <y_amount>100</y_amount>
                  <button/>
                  <style/>
                  <urls>
                    <urls_item>
                      <lang>de-at</lang>
                      <url>!"https://lehre.bpm.in.tum.de/~ge82bob/frames/landing.html?instance=" + cpee.instance_url + "&amp;framesid=alexTest"</url>
                    </urls_item>
                  </urls>
                  <default/>
                </arguments>
              </parameters>
              <code>
                <signal>false</signal>
                <prepare>endpoints.frames_display += attributes.framesid</prepare>
                <finalize output="result">data.category = result
data.timer = true</finalize>
                <update output="result"/>
                <rescue output="result"/>
              </code>
              <annotations>
                <_generic/>
                <_logging_behavior>
                  <_exclude>false</_exclude>
                  <_include>false</_include>
                </_logging_behavior>
                <_timing>
                  <_timing_weight/>
                  <_timing_avg/>
                  <explanations/>
                </_timing>
                <_shifting>
                  <_shifting_type>Duration</_shifting_type>
                </_shifting>
                <_context_data_analysis>
                  <probes/>
                  <ips/>
                </_context_data_analysis>
                <report>
                  <url/>
                </report>
                <_notes>
                  <_notes_general/>
                </_notes>
              </annotations>
              <documentation>
                <input/>
                <output/>
                <implementation>
                  <description/>
                </implementation>
                <code>
                  <description/>
                </code>
              </documentation>
            </call>
            <choose mode="exclusive" label="Show Results?">
              <alternative condition="data.category == 'blockbuster' || data.category == 'mixed' || data.category == 'arthouse'">
                <loop mode="post_test" condition="data.page_result != nil">
                  <_probability>
                    <_probability_min/>
                    <_probability_max/>
                    <_probability_avg/>
                  </_probability>
                  <call id="a4" endpoint="frames_display">
                    <parameters>
                      <label>Show Results Page</label>
                      <color/>
                      <arguments>
                        <type>wait</type>
                        <lx>0</lx>
                        <ly>0</ly>
                        <x_amount>100</x_amount>
                        <y_amount>100</y_amount>
                        <button/>
                        <style/>
                        <urls>
                          <urls_item>
                            <lang>de-at</lang>
                            <url>!"https://lehre.bpm.in.tum.de/~ge82bob/frames/results.html?category=" + data.category + "&amp;page=" + data.page_num.to_s + (data.favourite_cinema.to_s.strip.empty? ? "" : "&amp;favorites=" + data.favourite_cinema.to_s) + "&amp;instance=" + cpee.instance_url</url>
                          </urls_item>
                        </urls>
                        <default/>
                      </arguments>
                    </parameters>
                    <code>
                      <signal>false</signal>
                      <prepare>endpoints.frames_display += attributes.framesid</prepare>
                      <finalize output="result">if result.to_s.start_with?('page:')
  data.page_num = result.split(':')[1].to_i
  data.page_result = 'continue'
else
  data.selected_movie = result
  data.page_num = 0
  data.page_result = nil
end
data.timer = true</finalize>
                      <update output="result"/>
                      <rescue output="result"/>
                    </code>
                    <annotations>
                      <_generic/>
                      <_logging_behavior>
                        <_exclude>false</_exclude>
                        <_include>false</_include>
                      </_logging_behavior>
                      <_timing>
                        <_timing_weight/>
                        <_timing_avg/>
                        <explanations/>
                      </_timing>
                      <_shifting>
                        <_shifting_type>Duration</_shifting_type>
                      </_shifting>
                      <_context_data_analysis>
                        <probes/>
                        <ips/>
                      </_context_data_analysis>
                      <report>
                        <url/>
                      </report>
                      <_notes>
                        <_notes_general/>
                      </_notes>
                    </annotations>
                    <documentation>
                      <input/>
                      <output/>
                      <implementation>
                        <description/>
                      </implementation>
                      <code>
                        <description/>
                      </code>
                    </documentation>
                  </call>
                </loop>
                <call id="a5" endpoint="frames_display">
                  <parameters>
                    <label>Show Detail Page</label>
                    <color/>
                    <arguments>
                      <type>wait</type>
                      <lx>0</lx>
                      <ly>0</ly>
                      <x_amount>100</x_amount>
                      <y_amount>100</y_amount>
                      <button/>
                      <style/>
                      <urls>
                        <urls_item>
                          <lang>de-at</lang>
                          <url>!"https://lehre.bpm.in.tum.de/~ge82bob/frames/detail.html?movie=" + data.selected_movie.to_s + "&amp;category=" + data.category + "&amp;instance=" + cpee.instance_url</url>
                        </urls_item>
                      </urls>
                      <default/>
                    </arguments>
                  </parameters>
                  <code>
                    <signal/>
                    <prepare>endpoints.frames_display += attributes.framesid</prepare>
                    <finalize output="result">data.selected_movie = nil
data.timer = true</finalize>
                    <update output="result"/>
                    <rescue output="result"/>
                  </code>
                  <annotations>
                    <_generic/>
                    <_timing>
                      <_timing_weight/>
                      <_timing_avg/>
                      <explanations/>
                    </_timing>
                    <_shifting>
                      <_shifting_type>Duration</_shifting_type>
                    </_shifting>
                    <_context_data_analysis>
                      <probes/>
                      <ips/>
                    </_context_data_analysis>
                    <_notes>
                      <_notes_general/>
                    </_notes>
                  </annotations>
                  <documentation>
                    <input/>
                    <output/>
                    <implementation>
                      <description/>
                    </implementation>
                    <code>
                      <description/>
                    </code>
                  </documentation>
                </call>
              </alternative>
              <otherwise>
                <manipulate id="d4b" label="Skip Results">
                  <code>data.category = nil
data.category_name = nil</code>
                </manipulate>
              </otherwise>
            </choose>
          </parallel_branch>
          <parallel_branch>
            <loop mode="pre_test" condition="data.timer == true">
              <manipulate id="a6c" label="Reset Timer Flag">
                <code>data.timer = false</code>
              </manipulate>
              <call id="a6" endpoint="timeout">
                <parameters>
                  <label>Timer</label>
                  <color/>
                  <method>:post</method>
                  <arguments>
                    <timeout>60</timeout>
                    <data/>
                  </arguments>
                </parameters>
                <code>
                  <signal>false</signal>
                  <prepare/>
                  <finalize output="result"/>
                  <update output="result"/>
                  <rescue output="result"/>
                </code>
                <annotations>
                  <_generic/>
                  <_logging_behavior>
                    <_exclude>false</_exclude>
                    <_include>false</_include>
                  </_logging_behavior>
                  <_timing>
                    <_timing_weight/>
                    <_timing_avg/>
                    <explanations/>
                  </_timing>
                  <_shifting>
                    <_shifting_type>Duration</_shifting_type>
                  </_shifting>
                  <_context_data_analysis>
                    <probes/>
                    <ips/>
                  </_context_data_analysis>
                  <report>
                    <url/>
                  </report>
                  <_notes>
                    <_notes_general/>
                  </_notes>
                </annotations>
                <documentation>
                  <input/>
                  <output/>
                  <implementation>
                    <description/>
                  </implementation>
                  <code>
                    <description/>
                  </code>
                </documentation>
              </call>
            </loop>
            <manipulate id="a6b" label="Stop Loop">
              <code>data.running = false</code>
            </manipulate>
          </parallel_branch>
        </parallel>
        <_probability>
          <_probability_min/>
          <_probability_max/>
          <_probability_avg/>
        </_probability>
        <_annotations>
          <_logging_behavior>
            <_iteration>false</_iteration>
          </_logging_behavior>
        </_annotations>
        <manipulate id="d5" label="Reset for Next Iteration">
          <code>data.category = nil
data.selected_movie = nil
data.page_num = 0
data.page_result = 'continue'
data.timer = true
data.all_movies = []</code>
          <annotations>
            <_logging_behavior>
              <_exclude>false</_exclude>
            </_logging_behavior>
            <_context_data_analysis>
              <probes/>
            </_context_data_analysis>
          </annotations>
        </manipulate>
      </loop>
      <call id="a2" endpoint="stop_app">
        <parameters>
          <label>stop app</label>
          <color/>
          <arguments/>
        </parameters>
        <code>
          <signal>false</signal>
          <prepare/>
          <finalize output="result"/>
          <update output="result"/>
          <rescue output="result"/>
        </code>
        <annotations>
          <_generic/>
          <_logging_behavior>
            <_exclude>false</_exclude>
            <_include>false</_include>
          </_logging_behavior>
          <_timing>
            <_timing_weight/>
            <_timing_avg/>
            <explanations/>
          </_timing>
          <_shifting>
            <_shifting_type>Duration</_shifting_type>
          </_shifting>
          <_context_data_analysis>
            <probes/>
            <ips/>
          </_context_data_analysis>
          <report>
            <url/>
          </report>
          <_notes>
            <_notes_general/>
          </_notes>
        </annotations>
        <documentation>
          <input/>
          <output/>
          <implementation>
            <description/>
          </implementation>
          <code>
            <description/>
          </code>
        </documentation>
      </call>
      <stop id="d_end"/>
    </description>
  </description>
  <transformation>
    <description type="copy"/>
    <dataelements type="none"/>
    <endpoints type="none"/>
  </transformation>
</testset>