      <choose mode="exclusive" label="Scraping needed?">
        <alternative condition="data.needs_scraping == true">
          <call id="d_subprocess" endpoint="subprocess">
            <parameters>
              <label>Run Scraper (Process 1)</label>
              <color/>
              <arguments>
                <behavior>wait_running</behavior>
                <url>https://cpee.org/hub/server/Teaching.dir/Prak.dir/TUM-Prak-25-WS.dir/MadausAlexander.dir/scraper_orchestrator.xml</url>
                <init/>
                <endpoints/>
                <attributes/>
                <customization/>
              </arguments>
            </parameters>
            <code>
              <signal>false</signal>
              <prepare/>
              <finalize output="result"/>
              <update output="result"/>
              <rescue output="result"/>
            </code>
            <annotations>
              <_generic/>
              <_timing>
                <_timing_weight/>
                <_timing_avg/>
                <explanations/>
              </_timing>
              <_shifting>
                <_shifting_type>Duration</_shifting_type>
              </_shifting>
              <_context_data_analysis>
                <probes/>
                <ips/>
              </_context_data_analysis>
              <_notes>
                <_notes_general/>
